{
  "version": 2,
  "public": true,
  "name": "project-a-frontend",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "installCommand": "flutter/bin/flutter precache && flutter/bin/flutter config --enable-web",
  "buildCommand": "flutter/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "framework": null
}
